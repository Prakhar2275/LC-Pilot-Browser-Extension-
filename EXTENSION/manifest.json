{
  "manifest_version": 3,
  "name": "LC Buddy",
  "version": "1.0.0",
  "description": "Step-by-step LeetCode mentor. Hints, not solutions.",

  "permissions": ["scripting", "tabs", "storage"],

  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["sidebar/index.html", "sidebar/assets/*"],
      "matches": ["https://leetcode.com/*"]
    }
  ]


}
